digraph G {
	compound = true;

	"parse command" -> "chose stack/heap out"
	"parse command" -> "chose refresh time"

	"chose stack/heap out" -> "draw changes" [lhead=cluster_group]
	"chose refresh time" -> "draw changes" [lhead=cluster_group]

	subgraph cluster_group {
		"parse memory" -> "get terminal info" -> "draw changes"
		"draw changes" -> "get hotkey" -> "chose stack/heap in" -> "parse memory"
	}

	"chose stack/heap out" [label="chose stack/heap"]
	"chose stack/heap in" [label="chose stack/heap"]
}
